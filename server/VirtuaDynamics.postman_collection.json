{
  "info": {
    "name": "VirtuaDynamics API",
    "description": "Complete API collection for VirtuaDynamics local backend.\n\n**Setup:**\n1. Run the `Auth > Create Session` request first to get a JWT token.\n2. The token is automatically saved to the `token` collection variable.\n3. All subsequent requests use this token via the `Authorization` header.\n\n**Variables:**\n- `baseUrl` — your server URL (default: http://localhost:3000)\n- `token` — JWT token (auto-set after session creation)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "vitalId",
      "value": ""
    },
    {
      "key": "droneId",
      "value": ""
    },
    {
      "key": "incidentId",
      "value": ""
    },
    {
      "key": "contactId",
      "value": ""
    },
    {
      "key": "deviceId",
      "value": ""
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Health Check",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": ["{{baseUrl}}"],
              "path": ["health"]
            },
            "description": "Check if the server is running."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Create Session",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.success && res.token) {",
                  "    pm.collectionVariables.set('token', res.token);",
                  "    console.log('Token saved to collection variable');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"externalUserId\": \"12345\",\n  \"email\": \"testuser@example.com\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/session",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "session"]
            },
            "description": "Exchange VirtuaLogin external user for a local JWT. Token is auto-saved to the `token` variable."
          },
          "response": []
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/auth/logout",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "logout"]
            },
            "description": "Logout (server-side is stateless, clears client token)."
          },
          "response": []
        }
      ]
    },
